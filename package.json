{
  "name": "i18n-collector",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "make dev",
    "dev:api": "make dev-api",
    "dev:web": "pnpm --filter web-ui dev",
    "build:web": "pnpm --filter web-ui build",
    "lint:web": "pnpm --filter web-ui lint",
    "test:e2e": "pnpm --filter e2e-tests test"
  }
}