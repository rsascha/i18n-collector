# Kopie dieser Datei zu `.env` anlegen und Werte für lokale Entwicklung anpassen.
# Wird von docker compose gelesen und kann vor `./mvnw spring-boot:run` gesourced werden.

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=translations
DB_USERNAME=translations
DB_PASSWORD=translations

# --- AWS Bedrock ---
# Setup-Reihenfolge:
#   1) AWS-Console: Bedrock → "Model access" → Anthropic-Modelle aktivieren
#      (geht nur über die Console, weder CLI noch CDK).
#   2) IAM-User/Rolle mit Permissions: bedrock:InvokeModel + bedrock:Converse.
#   3) Modell-ID: Claude 4.x in eu-central-1 erfordert ein EU-Inference-Profile
#      (Präfix `eu.`); direkte Modell-IDs (`anthropic.claude-haiku-...`) werden
#      vom Converse-API mit ValidationException abgewiesen.
#      Verfügbar: aws bedrock list-inference-profiles --region eu-central-1
#   4) Credentials hier eintragen ODER via ~/.aws/credentials + AWS_PROFILE.
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=default
