# Kopie dieser Datei zu `.env` anlegen und Werte für lokale Entwicklung anpassen.
# Wird von docker compose gelesen und kann vor `./mvnw spring-boot:run` gesourced werden.

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=translations
DB_USERNAME=translations
DB_PASSWORD=translations

# --- AWS Bedrock ---
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS-Credentials per Profil oder explizit setzen
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=